{
  "name": "@inthegreenyet/backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=default --reporter=junit --outputFile.junit=test-report.junit.xml",
    "lint": "eslint .",
    "typecheck": "pnpm run cf-typegen && tsc --noEmit && tsc -p test/tsconfig.json --noEmit",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "wrangler": "^4.86.0"
  },
  "dependencies": {
    "@notionhq/client": "^5.11.1"
  }
}
