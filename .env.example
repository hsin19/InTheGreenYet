# Notion OAuth (get from https://www.notion.so/profile/integrations)
VITE_NOTION_CLIENT_ID=your-client-id-here

# API base URL — leave UNSET for same-origin. The Worker serves the SPA and the
# /api, /auth routes on one origin (via @cloudflare/vite-plugin in dev/build), so
# the client uses relative paths. Only set this if you ever serve the SPA from a
# different origin than the Worker.
# VITE_API_BASE_URL=
