{
  "name": "inthegreenyet",
  "version": "1.0.0",
  "description": "It's not about today's profit — it's about knowing where you truly stand.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "CLOUDFLARE_ENV=dev vite",
    "build": "wrangler types > /dev/null && tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint": "eslint .",
    "typecheck": "wrangler types > /dev/null && tsc -b && tsc -p worker/test/tsconfig.json --noEmit",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "i18n:check": "lingui extract && lingui compile --strict",
    "test": "pnpm run test:spa && pnpm run test:worker",
    "test:spa": "vitest run",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "test:ui": "vitest --browser.headless=false",
    "test:coverage": "vitest run --coverage && vitest run --config vitest.worker.config.ts --coverage",
    "test:ci": "vitest run --coverage --reporter=default --reporter=junit --outputFile.junit=test-report.junit.xml && vitest run --config vitest.worker.config.ts --coverage --reporter=default --reporter=junit --outputFile.junit=worker-test-report.junit.xml",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "pnpm run format && pnpm run lint && pnpm run typecheck && pnpm run i18n:check && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@lingui/core": "^6.4.0",
    "@lingui/react": "^6.4.0",
    "@notionhq/client": "^5.11.1",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "idb": "^8.0.3",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@eslint/js": "^10.0.1",
    "@lingui/cli": "^6.4.0",
    "@lingui/format-po": "^6.4.0",
    "@lingui/swc-plugin": "^6.4.0",
    "@lingui/vite-plugin": "^6.4.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/browser": "~4.1.9",
    "@vitest/browser-playwright": "~4.1.9",
    "@vitest/coverage-istanbul": "~4.1.8",
    "@vitest/coverage-v8": "~4.1.8",
    "autoprefixer": "^10.4.27",
    "dprint": "^0.54.0",
    "eslint": "^10.6.0",
    "eslint-plugin-lingui": "^0.14.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "lint-staged": "^17.0.5",
    "playwright": "^1.60.0",
    "postcss": "^8.5.8",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.0.14",
    "vite-imagetools": "^10.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "~4.1.9",
    "vitest-browser-react": "^2.2.0",
    "workbox-window": "^7.4.1",
    "wrangler": "^4.105.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*": "dprint fmt --allow-no-files",
    "*.{js,ts,tsx,jsx}": "eslint --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hsin19/InTheGreenYet.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/hsin19/InTheGreenYet/issues"
  },
  "homepage": "https://github.com/hsin19/InTheGreenYet#readme"
}
