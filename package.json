{
  "name": "inthegreenyet",
  "version": "1.0.0",
  "description": "It's not about today's profit — it's about knowing where you truly stand.",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --workspace=@inthegreenyet/frontend",
    "dev:backend": "npm run dev --workspace=@inthegreenyet/backend",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run format && npm run lint && npm run test && npm run build",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hsin19/InTheGreenYet.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/hsin19/InTheGreenYet/issues"
  },
  "homepage": "https://github.com/hsin19/InTheGreenYet#readme",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260529.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "concurrently": "^10.0.0",
    "dprint": "^0.54.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lint-staged": "^17.0.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "~4.1.7"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "dprint fmt",
    "*.{js,ts,tsx,jsx}": "eslint --fix"
  },
  "allowScripts": {
    "esbuild@0.27.3": true,
    "esbuild@0.25.12": true,
    "esbuild@0.27.7": true,
    "@swc/core@1.15.40": true,
    "fsevents@2.3.3": true,
    "dprint@0.54.0": true,
    "workerd@1.20260526.1": true,
    "sharp@0.34.5": true,
    "sharp@0.33.5": true,
    "simple-git-hooks@2.13.1": true,
    "msw@2.14.6": true
  }
}
