{
  "name": "inthegreenyet",
  "version": "1.0.0",
  "description": "It's not about today's profit — it's about knowing where you truly stand.",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
    "dev:frontend": "pnpm --filter @inthegreenyet/frontend dev",
    "dev:backend": "pnpm --filter @inthegreenyet/backend dev",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "lint": "pnpm -r lint",
    "build": "pnpm -r build",
    "check": "pnpm run format && pnpm run lint && pnpm run test && pnpm run build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:ci": "pnpm -r test:ci"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hsin19/InTheGreenYet.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/hsin19/InTheGreenYet/issues"
  },
  "homepage": "https://github.com/hsin19/InTheGreenYet#readme",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260529.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@vitest/coverage-istanbul": "~4.1.8",
    "@vitest/coverage-v8": "~4.1.8",
    "concurrently": "^10.0.0",
    "dprint": "^0.54.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lint-staged": "^17.0.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "~4.1.7"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*": "dprint fmt",
    "*.{js,ts,tsx,jsx}": "eslint --fix"
  }
}
