{
  "name": "inthegreenyet",
  "version": "1.0.0",
  "description": "It's not about today's profit — it's about knowing where you truly stand.",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --workspace=@inthegreenyet/frontend",
    "dev:backend": "npm run dev --workspace=@inthegreenyet/backend",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hsin19/InTheGreenYet.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/hsin19/InTheGreenYet/issues"
  },
  "homepage": "https://github.com/hsin19/InTheGreenYet#readme",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "dprint": "^0.52.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "~4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "dprint fmt",
    "*.{js,ts,tsx,jsx}": "eslint --fix"
  }
}
